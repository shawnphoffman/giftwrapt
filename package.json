{
	"name": "group-wish-lists-open",
	"version": "0.14.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"prepare": "husky",
		"dev": "vite dev --port ${PORT:-3000}",
		"build": "vite build && pnpm build:cli",
		"build:cli": "node scripts/build-cli.mjs",
		"vercel-build": "drizzle-kit migrate && vite build",
		"serve": "vite preview",
		"test": "vitest run",
		"lint": "eslint",
		"format": "prettier",
		"check": "prettier --config prettier.config.js --write . && eslint --fix",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx --env-file=.env.local scripts/seed.ts",
		"db:reset": "drizzle-kit push --force && pnpm db:seed",
		"admin:create": "tsx scripts/admin-create.ts",
		"admin:reset-password": "tsx scripts/admin-reset-password.ts",
		"storage:init": "tsx scripts/init-garage.ts",
		"storybook": "STORYBOOK=true storybook dev -p 6006",
		"build-storybook": "STORYBOOK=true storybook build",
		"build-email": "email build --dir src/emails --packageManager pnpm",
		"dev-email": "email dev --dir src/emails -p 3001",
		"export-email": "email export --dir src/emails --packageManager pnpm"
	},
