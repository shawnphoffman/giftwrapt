# =============================================================================
# GiftWrapt — Screenshot Generator Environment
# =============================================================================
# Template for `pnpm dev:screenshots` and `pnpm screenshots`. Run
# `pnpm setup:env` to copy this file to .env.local.screenshots and replace
# placeholder secrets with cryptographically-random values.
#
# This env uses a separate database (giftwrapt_dev_screenshots) on the same
# postgres container as the dev DB. The vite dev server runs on a separate
# port (3003) so screenshots and regular dev can coexist if needed.
#
# Storage values are intentionally fake — the screenshot run boots an S3
# client but never makes outbound calls to it.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_URL=http://localhost:3003
PORT=3003
DATABASE_URL=postgresql://postgres:password@localhost:54321/giftwrapt_dev_screenshots
BETTER_AUTH_URL=http://localhost:3003
BETTER_AUTH_SECRET=replace-with-random-secret

# -----------------------------------------------------------------------------
# Client
# -----------------------------------------------------------------------------
VITE_SERVER_URL=http://localhost:3003

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=warn
LOG_PRETTY=true

# -----------------------------------------------------------------------------
# Fake storage (the screenshot dev server never makes real S3 calls)
# -----------------------------------------------------------------------------
# STORAGE_SKIP_BOOT_CHECK disables the boot-time HeadBucket probe that would
# otherwise crash on the fake endpoint below. Keep the STORAGE_* vars set so
# `isStorageConfigured()` returns true and the rest of the app behaves
# normally (image URL generation, S3 client construction, etc.).
STORAGE_SKIP_BOOT_CHECK=true
STORAGE_ENDPOINT=http://storage.example.test
STORAGE_REGION=us-east-1
STORAGE_BUCKET=giftwrapt-screenshots
STORAGE_ACCESS_KEY_ID=screenshot-fake-key-id
STORAGE_SECRET_ACCESS_KEY=screenshot-fake-secret
STORAGE_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# TanStack devtools (off so they don't appear in captures)
# -----------------------------------------------------------------------------
VITE_TANSTACK_DEVTOOLS=false
TANSTACK_DEVTOOLS=false
