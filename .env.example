# =============================================================================
# HoffStuff / Wish Lists — Environment Variables
# =============================================================================
# Copy this file to .env (for Docker self-hosting) or .env.local (for local dev).
# Variables marked [required] must be set; others have sensible defaults.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# [required] PostgreSQL connection string.
# For Docker self-hosting, this is auto-constructed from POSTGRES_* vars below.
# For local dev: DATABASE_URL=postgresql://postgres:password@localhost:54321/wishlist_dev
DATABASE_URL=postgresql://postgres:password@postgres:5432/wishlist

# Used by docker-compose.selfhost.yml to configure the Postgres container
# and construct DATABASE_URL automatically.
POSTGRES_DB=wishlist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-use-a-strong-password

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# [required] Secret key for Better Auth session signing. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# [required for non-localhost deployments] Public URL the app is served from.
# Used for the session cookie domain and better-auth's trusted-origin check.
# Must include protocol, host, and port, e.g. http://192.168.1.137:3888 or
# https://wishlists.example.com. If unset, defaults to http://localhost:3000
# and sign-in/sign-up will fail from any other origin.
BETTER_AUTH_URL=http://localhost:3000

# Public-facing server URL (used in emails and OpenGraph).
# SERVER_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Email (Resend) — optional
# -----------------------------------------------------------------------------
# Sign up at https://resend.com for an API key.
# Without these, email features (comments, birthdays) are silently disabled.
# RESEND_API_KEY=re_xxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@your-domain.com
# RESEND_FROM_NAME=Wish Lists
# RESEND_BCC_ADDRESS=admin@your-domain.com

# -----------------------------------------------------------------------------
# Cron jobs — optional
# -----------------------------------------------------------------------------
# Secret to protect the /api/cron/* endpoints from public access.
# Set this and pass it as a Bearer token when calling cron routes.
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain.com/api/cron/birthday-emails
# CRON_SECRET=change-me-to-a-random-secret

# -----------------------------------------------------------------------------
# Docker image override — optional
# -----------------------------------------------------------------------------
# Override the app image used in docker-compose.selfhost.yml.
# APP_IMAGE=ghcr.io/shawnphoffman/wish-lists:latest

# -----------------------------------------------------------------------------
# Client-side — optional
# -----------------------------------------------------------------------------
# App title displayed in the browser tab and sidebar.
# VITE_APP_TITLE=Wish Lists
