APP_IMAGE=ghcr.io/your-org/wish-lists:latest

POSTGRES_DB=wishlists
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

BETTER_AUTH_SECRET=change-me
SERVER_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

VITE_APP_TITLE=Wish Lists
VITE_SERVER_URL=http://localhost:3000

# Multi-origin / LAN access (optional). Set these if you reach the same
# instance from more than one hostname, e.g. https://wish.example.com plus
# http://192.168.1.137:3888 on your LAN.
#
# TRUSTED_ORIGINS adds extra origins to better-auth's allow-list (BETTER_AUTH_URL
# is always trusted). Comma-separated.
# TRUSTED_ORIGINS=http://192.168.1.137:3888
#
# INSECURE_COOKIES drops the Secure flag on auth cookies. Required if any
# trusted origin is plain HTTP, because browsers refuse to store Secure
# cookies on HTTP pages. Weakens session security on the HTTPS path too,
# so leave unset unless you actually need HTTP origin login to work.
# INSECURE_COOKIES=true

# Optional email settings (all transactional email is powered by Resend).
# If RESEND_API_KEY and RESEND_FROM_EMAIL are unset the app still runs:
# comment notifications, birthday emails, the post-birthday gift summary,
# and the admin "send test email" action all no-op, and the matching
# admin toggles are hidden from the settings UI.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_FROM_NAME=
# RESEND_BCC_ADDRESS=

# Object storage (S3-compatible). Required; server refuses to boot without
# these. Any S3-compatible bucket works: Garage (bundled as an optional
# compose sidecar), AWS S3, Cloudflare R2, Supabase Storage, etc.
# See docs/storage.md for recipes.
STORAGE_ENDPOINT=http://garage:3900
STORAGE_REGION=garage
STORAGE_BUCKET=wishlists
# Garage enforces specific formats (AWS/R2 are lax):
#   key id:     "GK" + 24 hex chars       ->  printf 'GK%s' "$(openssl rand -hex 12)"
#   secret key: 64 hex chars              ->  openssl rand -hex 32
# Garage tombstones deleted keys so the IDs can't be reused; rotate by
# picking new values AND running `docker compose down -v` to wipe the volume.
STORAGE_ACCESS_KEY_ID=GKreplace-with-24-hex-chars
STORAGE_SECRET_ACCESS_KEY=replace-with-64-hex-chars
STORAGE_FORCE_PATH_STYLE=true   # true for Garage/MinIO, false for AWS/R2
# STORAGE_PUBLIC_URL=           # unset = app serves via /api/files/*; set to a
                                # CDN base URL (e.g. https://cdn.example.com) to
                                # hand clients direct-CDN URLs instead
# STORAGE_MAX_UPLOAD_MB=8       # max upload size before Sharp runs

# Bundled Garage sidecar only. When INIT_GARAGE=true, the app's entrypoint
# bootstraps Garage via its admin HTTP API before starting the server
# (layout assign, bucket create, key import, grant permissions). Idempotent.
# Leave unset for external S3 deploys; no other vars in this section apply.
INIT_GARAGE=true
GARAGE_RPC_SECRET=change-me-to-a-64-char-hex-string
GARAGE_ADMIN_TOKEN=change-me-to-a-64-char-hex-string
# GARAGE_ADMIN_URL=http://garage:3903   # default matches the compose service
