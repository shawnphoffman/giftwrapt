# =============================================================================
# GiftWrapt — Local Development Environment
# =============================================================================
# Template for local dev against the bundled docker-compose.yaml stack.
# Run `pnpm setup:env` to copy this file to .env.local and replace every
# placeholder secret with a cryptographically-random value. Idempotent.
#
# For self-hosted Docker deploys (separate compose files under docker/) see
# .env.example instead — that one's tuned for the in-cluster hostnames.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# The dev compose (docker-compose.yaml) provisions a postgres container
# named giftwrapt-dev-postgres listening on host port 54321, with database
# `giftwrapt_dev` auto-created via POSTGRES_DB on first boot.
DATABASE_URL=postgresql://postgres:password@localhost:54321/giftwrapt_dev

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-with-random-secret
BETTER_AUTH_URL=http://localhost:3001
VITE_SERVER_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Email (Resend) — optional
# -----------------------------------------------------------------------------
# Without these, email features no-op silently in dev. Fine for most work.
# RESEND_API_KEY=re_xxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@your-domain.com
# RESEND_FROM_NAME=GiftWrapt
# RESEND_BCC_ADDRESS=admin@your-domain.com

# -----------------------------------------------------------------------------
# Cron — optional in dev
# -----------------------------------------------------------------------------
# Required for production self-host; in dev the /api/cron/* routes return 503
# if unset, which is harmless unless you're actively poking them.
# CRON_SECRET=replace-with-random-secret

# -----------------------------------------------------------------------------
# Object storage (Garage from docker-compose.yaml --profile garage)
# -----------------------------------------------------------------------------
# Garage runs in-cluster but is reached from `pnpm dev` (on the host) via
# localhost, not the docker service name. Run `pnpm storage:init` once after
# the first `docker compose --profile garage up -d` to create the bucket and
# import the key below.
STORAGE_ENDPOINT=http://localhost:3900
STORAGE_REGION=garage
STORAGE_BUCKET=giftwrapt
# Garage enforces these formats; `pnpm setup:env` produces compliant values:
#   key id:     "GK" + 24 hex chars
#   secret key: 64 hex chars
STORAGE_ACCESS_KEY_ID=GKreplace-with-24-hex-chars
STORAGE_SECRET_ACCESS_KEY=replace-with-64-hex-chars
STORAGE_FORCE_PATH_STYLE=true

# Bundled Garage daemon secrets (consumed by docker-compose.yaml).
GARAGE_RPC_SECRET=replace-with-64-hex-chars
GARAGE_ADMIN_TOKEN=replace-with-64-hex-chars
# Garage admin API binds on the host as port 3903.
GARAGE_ADMIN_URL=http://localhost:3903

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info        # fatal | error | warn | info | debug | trace | silent
LOG_PRETTY=true       # pretty output for local dev; prod sets false
